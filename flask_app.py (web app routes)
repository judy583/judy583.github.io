from flask import Flask

app = Flask(__name__)

common_style = """
    <style>
        body { background-color: #fdf5e6; text-align: center; font-family: sans-serif; padding: 50px; }
        h1 { font-size: 50px; }
        .nav-link { display: inline-block; margin: 10px; padding: 10px 20px; background: #fff; border: 1px solid #ccc; text-decoration: none; color: #333; border-radius: 5px; }
        .nav-link:hover { background: #eee; }
        img { border-radius: 15px; margin: 20px; box-shadow: 0 4px 8px rgba(0,0,0,0.2); }
    </style>
"""

@app.route("/")
def index():
    return f'''
    <head>{common_style}</head>
    <body>
        <h1>Welcome to My Fruit World</h1>
        <img src="static/fruit.png" width=300>
        <p>This is the main page of my Flask application.</p>
        <br>
        <a class="nav-link" href="/banana">Banana Page</a>
        <a class="nav-link" href="/apple">Apple Page</a>
        <a class="nav-link" href="/grape">Grape Page</a>
        <a class="nav-link" href="/orange">Orange Page</a>
        <a class="nav-link" href="/strawberry">Strawberry Page</a>
    </body>
    '''

@app.route("/banana")
def banana():
    return f'''
    <head>{common_style}<style>h1 {{ color: yellow; text-shadow: 2px 2px #000; }}</style></head>
    <body>
        <h1>Yellow Banana</h1>
        <img src="static/banana.png" width=200>
        <p>Bananas are curved, yellow fruits.</p>
        <br><a class="nav-link" href="/">Go Back Home</a>
    </body>
    '''

