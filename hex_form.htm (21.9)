<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>Hex Code Validator</title>
    <link rel="stylesheet" type="text/css" href="{{ url_for('static', filename='style.css') }}">
</head>
<body>
    <h1>Hex Code Check</h1>
    <p>{{ feedback }}</p> <form action="/hex_form" method="POST">
        <label>Enter a code: #
            <input type="text" name="hex" value="{{ hex }}" required/>
        </label><br>
        
        <input type="color" value="#{{ hex }}" disabled/><br><br>
        
        <button type="submit">Check Hex Code</button>
    </form>

    <br>
    <img src="{{ url_for('static', filename='hex_figure.png') }}" alt="Hex Illustration" width="200">
</body>
</html>
